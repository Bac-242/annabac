---
import Layout from '../layouts/Layout.astro';
import Fil from '../components/Fil.astro';
---

<Layout titre="Recherche" description="Rechercher un sujet ou un corrigé du baccalauréat congolais.">
  <Fil items={[{ href: '/', label: 'Accueil' }, { label: 'Recherche' }]} />
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Rechercher</h1>
  <p class="mt-2 text-[color:var(--color-muted)]">
    Trouvez un sujet par matière, année, chapitre ou mot-clé.
  </p>

  <!-- Squelette affiché tant que Pagefind n'est pas monté (réseau lent). -->
  <div id="recherche-skeleton" class="mt-8" aria-hidden="true">
    <div class="skeleton h-11 w-full rounded-full"></div>
    <div class="mt-6 grid gap-3">
      <div class="skeleton h-16 w-full"></div>
      <div class="skeleton h-16 w-full"></div>
      <div class="skeleton h-16 w-full"></div>
    </div>
  </div>

  <div id="recherche" class="mt-8"></div>

  <p class="mt-8 text-sm text-[color:var(--color-muted)]">
    Vous ne trouvez pas ? Parcourez par
    <a href="/series" class="text-[color:var(--color-accent)] hover:underline">série</a>,
    <a href="/annees" class="text-[color:var(--color-accent)] hover:underline">année</a> ou
    <a href="/matieres" class="text-[color:var(--color-accent)] hover:underline">matière</a>,
    ou <a href="/contribuer" class="text-[color:var(--color-accent)] hover:underline">proposez le document</a>.
  </p>

  <!-- Pagefind est généré au build ; absent en mode dev. is:inline évite que
       Astro tente de bundler ces fichiers (qui n'existent pas encore). -->
  <link is:inline href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const el = document.getElementById('recherche');
      const skeleton = document.getElementById('recherche-skeleton');
      if (skeleton) skeleton.remove();
      if (window.PagefindUI) {
        new window.PagefindUI({
          element: '#recherche',
          showSubResults: true,
          translations: {
            placeholder: 'Rechercher un sujet…',
            zero_results: 'Aucun résultat pour « [SEARCH_TERM] »',
          },
        });
        var q = new URLSearchParams(location.search).get('q');
        if (q) {
          var champ = document.querySelector('#recherche input');
          if (champ) {
            champ.value = q;
            champ.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }
      } else {
        el.innerHTML =
          '<p class="rounded bg-amber-50 p-4 text-sm text-amber-800">La recherche est disponible une fois le site généré : <code>npm run build</code> puis <code>npm run preview</code>.</p>';
      }
    });
  </script>
</Layout>
