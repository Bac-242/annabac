---
import type { Sujet } from '../lib/data';
import { statutSujet } from '../lib/data';
import BadgeStatut from './BadgeStatut.astro';

interface Props {
  sujet: Sujet;
  montrerSerie?: boolean;
}
const { sujet, montrerSerie = false } = Astro.props;
const { data } = sujet;
const href = `/sujets/${sujet.slug}`;
const statut = statutSujet(data);
---

<a href={href} class="card card-hover group flex flex-col p-5">
  <div class="flex items-start justify-between gap-2">
    <div>
      <p class="text-xs text-[color:var(--color-muted)]">
        {data.annee} · Session {data.session.toLowerCase()}
      </p>
      <h3 class="mt-1 font-semibold tracking-tight text-[color:var(--color-ink)]">
        {data.matiere}
      </h3>
      {montrerSerie && (
        <p class="text-xs text-[color:var(--color-muted)]">Série {data.serie}</p>
      )}
    </div>
    <BadgeStatut statut={statut} />
  </div>

  <p class="mt-auto pt-4 text-xs text-[color:var(--color-muted)]">
    {statut === 'a-venir'
      ? 'Document non encore disponible'
      : [data.sujetPdf && 'Sujet', data.corrigePdf && 'Corrigé']
          .filter(Boolean)
          .join(' · ') + ' · PDF'}
  </p>
</a>
